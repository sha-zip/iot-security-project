openssl_conf= openss_init
[openssl_init]
providers= provider_sect
#engines = engine_sect 
[provider_sect]
default = default_sect
pkcs11=pkcs11_sect
[default_sect]
activate=1
[pkcs11_sect]

cat > ~/openssl3-pkcs11.cnf << 'EOF'
openssl_conf= openss_init
[openssl_init]
providers= provider_sect
#engines = engine_sect 
[provider_sect]
default = default_sect
pkcs11=pkcs11_sect
[default_sect]
activate=1
[pkcs11_sect]


module = /usr/lib/x86_64-linux-gnu/engines-1.1/libpkcs11.so
activate=1
[engine_sect]
pkcs11= pkcs11_engine_sect
[pkcs11_engine_sect]
engine_id = pkcs11
dynamic_path= /usr/lib/x86_64-linux-gnu/engines-1.1/pkcs11.so
MODULE_PATH= /usr/lib/softhsm/libsofthsm2.so
#init=0
