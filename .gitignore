# Python
__pycache__/
*.py[cod]

# Virtual environments
venv/
.venv/
env/
platform/backend/venv/

# Environment and secrets
.env
.env.*
secrets/
certs/

# Crypto / private material
*.key
*private*.pem
*.p12
*.pfx
*.csr
*.srl

# Public key artifacts
*.der

# PKI files
pki/*.key
pki/*.csr
pki/*.srl
pki/ca.key
pki/index.txt
pki/index.txt.attr
pki/index.txt.old
pki/serial
pki/serial.old
pki/*.old
pki/ca.crl

# Ignore PEMs in PKI by default
pki/*.pem

# Keep public cert examples if needed
!pki/public/
!pki/public/*.pem
!pki/public/*.der

# Docker / runtime
*.pid

# OS / IDE
.DS_Store
.vscode/
.idea/
